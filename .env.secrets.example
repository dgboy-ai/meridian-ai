# Secrets for docker-compose (copy to .env.secrets and fill in values)
# This file is gitignored — never commit real secrets.

# Groq API key (free tier: https://console.groq.com)
GROQ_API_KEY=

# DataHub GMS token (for real DataHub integration)
DATAHUB_GMS_TOKEN=

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=

# PostgreSQL password (if using postgres persistence)
POSTGRES_PASSWORD=
