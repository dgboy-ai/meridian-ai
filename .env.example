# Meridian AI Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Groq API key (free tier: https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# DataHub configuration
# Set to "false" when running with docker compose (real DataHub)
# Set to "true" for local development without DataHub
DATAHUB_MOCK=true
DATAHUB_GMS_URL=http://localhost:8080/api/gms
DATAHUB_GMS_TOKEN=

# Application
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Security
# Set to "true" to enable JWT authentication
AUTH_ENABLED=false
# Secret key for JWT tokens (generate a random string for production)
JWT_SECRET_KEY=change-me-in-production
# CORS origins (comma-separated, or * for dev)
CORS_ORIGINS=*
# Max request body size in bytes (default 10MB)
MAX_BODY_SIZE=10485760

# Rate Limiting
MAX_RPM=60
REQUEST_TIMEOUT=30
